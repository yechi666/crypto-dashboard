# Copy to .env and adjust as needed (root .env is used by both server and docker-compose).
# Never commit the real .env file.

# --- Database (matches docker-compose.yml defaults) ---
DATABASE_URL="postgresql://crypto:crypto@localhost:5432/crypto_dashboard?schema=public"

# --- Server ---
PORT=4000
CORS_ORIGIN="http://localhost:5173"

# How often the server polls CoinCap for fresh market data (ms).
# CoinCap's free tier allows ~200 req/min; one shared call every 30s is
# comfortably under that regardless of how many clients are connected.
POLL_INTERVAL_MS=30000

# How many top coins to display in the API and UI (ORDER BY marketCapRank ASC LIMIT).
COIN_COUNT=20

# How many top coins the poll loop fetches and stores each cycle.
# Should be >= COIN_COUNT. A buffer above COIN_COUNT (default 100) prevents
# coins near the display boundary from getting gappy PriceHistory when their
# rank fluctuates across poll cycles.
TRACKED_COIN_COUNT=100

# How long a snapshot is considered "live" before the UI flags it as stale,
# expressed as a multiple of POLL_INTERVAL_MS (2 = stale after 2 missed cycles).
STALE_AFTER_INTERVALS=2

# How long to retain price history rows (hours). Used by the retention cleanup
# that runs after each successful poll.
HISTORY_RETENTION_HOURS=24

# CoinCap API key — required for live data. Sent as a Bearer token on every
# request: Authorization: Bearer <COINCAP_API_KEY>. Get a free key at
# https://pro.coincap.io (CoinCap dashboard). If left blank the app still
# boots and serves whatever is already in the database, but the poll loop will
# fail every cycle and the UI will show a stale/error state (graceful degrade).
# Never commit a real key — only this blank placeholder is tracked.
COINCAP_API_KEY=

# Base URL for the CoinCap v3 REST API.
COINCAP_BASE_URL="https://rest.coincap.io/v3"

# Per-request abort timeout (ms) for calls to CoinCap. A request that takes
# longer than this is aborted and classified as a timeout rather than left to
# hang indefinitely.
UPSTREAM_TIMEOUT_MS=10000

# --- Client (Vite reads only VITE_* vars) ---
VITE_API_BASE_URL="http://localhost:4000"

# How long (ms) since the last successful update before the UI shows data as stale.
# ~2x the server POLL_INTERVAL_MS. Client-side safety net for a silently-stalled stream.
VITE_STALE_AFTER_MS=60000
