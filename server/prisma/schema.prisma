// Schema notes (see docs/ARCHITECTURE.md for full reasoning):
//
// - Coin holds the latest known snapshot per coin (id = stable slug from the
//   configured upstream provider, e.g. "bitcoin"). This is what /api/coins
//   serves — one row per coin, upserted every poll cycle. It IS the
//   "last-known-good" data source when upstream is unavailable.
// - PriceHistory is an append-only time series, one row per coin per poll.
//   Powers the "last hour" detail view from the database (a recordedAt-window
//   read), never from a fresh upstream call.
// - FetchLog records every poll attempt (success or failure) so the API can
//   report genuine staleness/error state instead of guessing from Coin rows
//   alone (a Coin table with no failures looks identical to one that's 10
//   minutes stale unless we track fetch attempts separately).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Coin {
  id                       String   @id // stable slug identifier from the configured upstream provider, e.g. "bitcoin"
  symbol                   String
  name                     String
  currentPrice             Decimal  @db.Decimal(24, 10)
  marketCap                Decimal  @db.Decimal(24, 2)
  marketCapRank            Int?
  volume24h                Decimal? @db.Decimal(24, 2)
  priceChangePercentage24h Float?
  lastUpdatedUpstream      DateTime // timestamp the upstream provider reported for this data
  updatedAt                DateTime @updatedAt // when WE last wrote this row

  history PriceHistory[]

  @@index([marketCapRank])
}

model PriceHistory {
  id         Int      @id @default(autoincrement())
  coinId     String
  coin       Coin     @relation(fields: [coinId], references: [id], onDelete: Cascade)
  price      Decimal  @db.Decimal(24, 10)
  volume24h  Decimal? @db.Decimal(24, 2)
  recordedAt DateTime @default(now())

  @@index([coinId, recordedAt])
  @@index([recordedAt])
}

enum FetchStatus {
  PROCESSING
  SUCCEEDED
  FAILED
}

model FetchLog {
  id           Int       @id @default(autoincrement())
  source       String // which upstream provider this attempt hit, e.g. "coincap"
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  status       FetchStatus @default(PROCESSING)
  coinsUpdated Int?
  errorMessage String?

  @@index([startedAt])
  @@index([status, startedAt])
}
